:: StoryScript [script]
document.addEventListener('DOMContentLoaded', () => {
  const carousel = document.getElementById('carousel');
  
  // Verify the element exists before adding event listeners
  if (carousel) {
    let isDown = false;
    let startX;
    let scrollLeft;

    carousel.addEventListener('mousedown', (e) => {
      isDown = true; 
      startX = e.pageX - carousel.offsetLeft; 
      scrollLeft = carousel.scrollLeft;
    });
    
    carousel.addEventListener('mouseleave', () => isDown = false);
    carousel.addEventListener('mouseup', () => isDown = false);
    
    carousel.addEventListener('mousemove', (e) => {
      if(!isDown) return; 
      e.preventDefault(); 
      const x = e.pageX - carousel.offsetLeft;
      carousel.scrollLeft = scrollLeft - (x - startX);
    });
  }
});


:: StoryStylesheet [stylesheet]
tw-sidebar {
  position: fixed;
  top: 1rem;
  right: 1rem;
  left: auto;
  width: auto;
  text-align: center;
  background-color: transparent;
}

tw-sidebar tw-icon:nth-of-type(1) {
  background-image: url('./arrow.svg');
  background-position: center center;
  background-repeat: no-repeat;
  background-size: 100%;
  margin: 0;
  color: transparent;
  opacity: .5;
}

tw-sidebar tw-icon:nth-of-type(1):hover {
  opacity: 1;
}

tw-sidebar tw-icon:nth-of-type(2) {
  display: none;
}

tw-story {
  background-color: #EBF3F9;
  color: #2C3E50;
  padding: 2rem;
}

tw-passage {
  background-image: url('./bloem.png');
  background-repeat: no-repeat;
  background-size: 275px auto; 
  padding: 50px 0 0 60px;
  
  background-clip: border-box; 
  border-left: 115px solid transparent;

  background-position: left -165px top -20px;
}

tw-expression tw-link {
  background-image: url('./button.svg');
  background-repeat: no-repeat;
  border: 0 solid #1A365D;
  border-radius: 15px;
  box-sizing: border-box;
  color: #2C3E50;
  display: flex;
  font-size: 1rem;
  font-weight: 700;
  justify-content: center;
  line-height: 1.75rem;
  padding: .75rem 1.65rem;
  position: relative;
  font-family: "Dreamy Angel";
  text-align: center;
  text-decoration: none #2C3E50 solid;
  text-decoration-thickness: auto;
  width: 100%;
  max-width: 460px;
  position: relative;
  cursor: pointer;
  transform: rotate(-2deg);
  user-select: none;
  -webkit-user-select: none;
  touch-action: manipulation;
}

tw-expression tw-link.visited {
  color: #2C3E50 !important;
}

tw-expression tw-link:hover {
  color: #6941E1 !important;
}

tw-expression tw-link:focus {
  outline: 0;
}

tw-expression tw-link:after {
  content: '';
  position: absolute;
  border: 1px solid #2C3E50;
  border-radius: 10px;
  bottom: 4px;
  left: 4px;
  width: calc(100% - 1px);
  height: calc(100% - 1px);
}

tw-expression tw-link:hover:after {
  bottom: 2px;
  left: 2px;
}

@media (min-width: 768px) {
  tw-expression tw-link {
    padding: .75rem 3rem;
    font-size: 1.25rem;
  }
}

h1 {
  color: #1A365D;
  width: 100%;
  display: inline-block;
  background-image: url(./underline_curl.svg);
  background-position: left bottom;
  background-repeat: no-repeat;
  background-size: 620px 100px;
  padding-bottom: 40px;
  margin-bottom: 1rem;
}

p {
  margin-top: 0;
}

i {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  
  display: inline-block;
  background-image: url(./underline.svg);
  background-position: left center;
  background-repeat: no-repeat;
  background-size: 100% 100%;
  padding-bottom: .5rem;
}