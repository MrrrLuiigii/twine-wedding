<style>
    .container {
        display: grid;
        grid-template-columns: calc(60% - 1rem) calc(40% - 1rem);
        gap: 2rem;
    }

    .carousel {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        width: 100%;
        scroll-timeline: --carouselTimeline inline;
        gap: 15px;
        padding: 3rem;
        padding-top: 0;
        box-sizing: border-box;
    }

    .carousel::-webkit-scrollbar {
        display: none;
    }

    .slide {
        flex: 0 0 85%;
        scroll-snap-align: center;
    }

    .slide img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 8px;
        filter: drop-shadow(3px 3px 1px #2c3e50);
    }
</style>}


